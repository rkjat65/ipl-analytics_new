# ── Required ──────────────────────────────────────────────
# Gemini API key for Ask Cricket AI feature
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth Client ID (for Sign in with Google)
GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# ── Optional ──────────────────────────────────────────────
# CORS origins (comma-separated, defaults to localhost)
# CORS_ORIGINS=https://your-app.railway.app,http://localhost:5173

# Cricket live scores (Sportmonks): when a finished IPL match is polled, ball-by-ball is exported to
# ipl_json/sm_<fixture_id>.json and merged into ipl.duckdb. Manual: python scripts/promote_sportmonks_match.py <fixture_id>

# Twitter/X API (for Social Posting)
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=
